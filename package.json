{
  "name": "grimtales",
  "version": "1.0.0",
  "description": "Gothic dark fantasy novel reading platform",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "seed": "node backend/db/seed.js",
    "client": "live-server --port=3000 --open=index.html",
    "build:frontend": "node build-frontend.js",
    "desktop": "electron electron-main.js",
    "build:desktop": "electron-builder"
  },
  "build": {
    "appId": "com.grimtales.desktop",
    "productName": "GrimTales",
    "directories": {
      "output": "dist"
    },
    "files": [
      "www/**/*",
      "electron-main.js"
    ],
    "extraMetadata": {
      "main": "electron-main.js"
    }
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.8.9",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.5",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "live-server": "^1.2.2",
    "nodemon": "^3.0.1"
  }
}
