{
  "version": 2,
  "name": "grimtales",
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/browse", "dest": "/browse.html" },
    { "src": "/search", "dest": "/search.html" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/register", "dest": "/register.html" },
    { "src": "/novel", "dest": "/novel-detail.html" },
    { "src": "/read", "dest": "/chapter-read.html" },
    { "src": "/author", "dest": "/author-profile.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/profile", "dest": "/user-profile.html" },
    { "src": "/settings", "dest": "/settings.html" },
    { "src": "/notifications", "dest": "/notifications.html" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
